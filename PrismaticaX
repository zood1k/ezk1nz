_G.WatermarkUpdateConnection = Services.RunService.Heartbeat:Connect(function(dt)
    if not _G.WatermarkGui or not _G.WatermarkGui.Parent then return end
    if not _G.WatermarkFrame or not _G.WatermarkFrame.Parent then return end

    _G.WatermarkFPSSmoothed = _G.WatermarkFPSSmoothed * 0.8 + (1 / math.max(dt, 0.001)) * 0.2

    _G.WatermarkCurrentTime = tick()

    if _G.WatermarkCurrentTime - _G.WatermarkFPSLabelLastUpdate >= 1.0 then
        _G.WatermarkFPSLabelLastUpdate = _G.WatermarkCurrentTime
        if _G.WatermarkFPSLabel and _G.WatermarkFPSLabel.Parent then
            _G.WatermarkFPSLabel.Text = "FPS: " .. math.floor(_G.WatermarkFPSSmoothed + 0.5)
        end
    end

    if _G.WatermarkCurrentTime - _G.WatermarkLastFullUpdate < _G.WatermarkUpdateInterval then
        _G.WatermarkCurrentOpacity = Settings.GUI_OPACITY or 0
        if _G.WatermarkCurrentOpacity ~= _G.WatermarkLastOpacity then
            _G.WatermarkLastOpacity = _G.WatermarkCurrentOpacity
        _G.WatermarkTrans = math.clamp(_G.WatermarkCurrentOpacity / 100, 0, 1)
        _G.WatermarkFrame.BackgroundTransparency = _G.WatermarkTrans
        _G.WatermarkShadow.ImageTransparency = 1
        _G.WatermarkLogoContainer.BackgroundTransparency = math.clamp(0.3 + 0.4 * _G.WatermarkTrans, 0, 1)
        end
        return
    end
    _G.WatermarkLastFullUpdate = _G.WatermarkCurrentTime

    if _G.WatermarkPingLabel and _G.WatermarkPingLabel.Parent then
        _G.WatermarkPingOk, _G.WatermarkPingRaw = pcall(function()
            return game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
        end)
        if _G.WatermarkPingOk and type(_G.WatermarkPingRaw) == "number" then
            _G.WatermarkPingSamples = _G.WatermarkPingSamples or {}
            table.insert(_G.WatermarkPingSamples, _G.WatermarkPingRaw)
            if #_G.WatermarkPingSamples > 10 then
                table.remove(_G.WatermarkPingSamples, 1)
            end
            _G.WatermarkPingSum = 0
            _G.WatermarkPingIdx = 1
            while _G.WatermarkPingIdx <= #_G.WatermarkPingSamples do
                _G.WatermarkPingSum = _G.WatermarkPingSum + _G.WatermarkPingSamples[_G.WatermarkPingIdx]
                _G.WatermarkPingIdx = _G.WatermarkPingIdx + 1
            end
            _G.WatermarkPingLabel.Text = "Ping: " .. math.floor(_G.WatermarkPingSum / #_G.WatermarkPingSamples) .. "ms"
        end
    end

    _G.WatermarkCurrentSecond = math.floor(tick())
    if _G.WatermarkCurrentSecond ~= _G.WatermarkLastSecond then
        _G.WatermarkLastSecond = _G.WatermarkCurrentSecond
        if _G.WatermarkTimeLabel and _G.WatermarkTimeLabel.Parent then
            _G.WatermarkElapsed = math.floor(tick() - (_G.WatermarkStartTime or tick()))
            _G.WatermarkH = math.floor(_G.WatermarkElapsed / 3600)
            _G.WatermarkM = math.floor((_G.WatermarkElapsed % 3600) / 60)
            _G.WatermarkS = _G.WatermarkElapsed % 60
            _G.WatermarkTimeLabel.Text = string.format("%02d:%02d:%02d", _G.WatermarkH, _G.WatermarkM, _G.WatermarkS)
        end
    end

    _G.WatermarkNewColorHash = tostring(Colors.Base) .. tostring(Colors.Border)
    if _G.WatermarkLastColors ~= _G.WatermarkNewColorHash then
        _G.WatermarkLastColors = _G.WatermarkNewColorHash
        _G.WatermarkFrame.BackgroundColor3 = Colors.Base
        _G.WatermarkStroke.Color = Colors.Border
        _G.WatermarkLogoContainer.BackgroundColor3 = Colors.Card
        _G.WatermarkLogoStroke.Color = Colors.Border
    end
end)

