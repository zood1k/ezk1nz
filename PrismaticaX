CloseSearch = function(instant)
    if not SEARCH_OPEN then return end
    SEARCH_OPEN = false
    LastSearchPosition = UI.SearchModal.Position
    if SearchModalTween then SearchModalTween:Cancel() end
    if instant then
        UI.SearchModal.Visible = false
        UI.ResultsContainer.Visible = false
        UI.SearchInput.Text = ""
        UI.SearchOverlay.Active = false
        return
    end
    SearchModalTween = Services.TweenService:Create(UI.SearchModal, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = UDim2.fromOffset(0, 0),
        BackgroundTransparency = 1
    })
    SearchModalTween:Play()
    if UI.ModalShadow then UI.ModalShadow.ImageTransparency = 1 end
    if UI.ModalStroke then UI.ModalStroke.Transparency = 0.2 end
    if UI.ModalIcon then
        Services.TweenService:Create(UI.ModalIcon, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {ImageTransparency = 1}):Play()
    end
    if UI.SearchInput then
        Services.TweenService:Create(UI.SearchInput, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {TextTransparency = 1}):Play()
    end
    if UI.CloseSearchBtn then
        Services.TweenService:Create(UI.CloseSearchBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            BackgroundTransparency = 1,
            TextTransparency = 1
        }):Play()
    end
    for _, ph in ipairs(Data.CustomPlaceholders) do
        if ph and ph.Parent and ph.Parent == UI.SearchInput then
            Services.TweenService:Create(ph, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {TextTransparency = 1}):Play()
        end
    end
    Services.TweenService:Create(UI.ResultsContainer, TweenInfo.new(0.15, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, 0)}):Play()
    task.delay(0.3, function()
        UI.SearchModal.Visible = false
        UI.ResultsContainer.Visible = false
        UI.SearchInput.Text = ""
        UI.SearchOverlay.Active = false
        for _, ph in ipairs(Data.CustomPlaceholders) do
            if ph and ph.Parent and ph.Parent == UI.SearchInput then
                ph.TextTransparency = 0
            end
        end
    end)
end

