    _G.sliderThumb.ZIndex = 2

    _G.sliderThumbCorner = Instance.new("UICorner", _G.sliderThumb)
    _G.sliderThumbCorner.CornerRadius = UDim.new(1, 0)

    _G.sliderReturnedCard = _G.sliderCard
    _G.sliderReturnedValueLabel = _G.sliderValueLabel
    _G.sliderReturnedFill = _G.sliderFill
    _G.sliderReturnedThumb = _G.sliderThumb

    table.insert(Data.AllSliders, {
        track = _G.sliderTrack,
        fill = _G.sliderReturnedFill,
        valueLabel = _G.sliderReturnedValueLabel,
        thumb = _G.sliderReturnedThumb
    })

    _G.sliderDragging = false
    _G.sliderCurrentTrack = _G.sliderTrack
    _G.sliderCurrentFill = _G.sliderReturnedFill
    _G.sliderCurrentThumb = _G.sliderReturnedThumb
    _G.sliderCurrentValueLabel = _G.sliderReturnedValueLabel
    _G.sliderCurrentMin = min
    _G.sliderCurrentMax = max
    _G.sliderCurrentCb = cb

    _G.sliderUpdateFn = function(inputPos)
        if not _G.sliderCurrentTrack or not _G.sliderCurrentTrack.Parent then
            _G.sliderDragging = false
            return
        end
        if not _G.sliderCurrentValueLabel or not _G.sliderCurrentValueLabel.Parent then
            _G.sliderDragging = false
            return
        end
        _G.sliderTrackAbsPos = _G.sliderCurrentTrack.AbsolutePosition
        _G.sliderTrackAbsSize = _G.sliderCurrentTrack.AbsoluteSize
        _G.sliderRelative = math.clamp((inputPos.X - _G.sliderTrackAbsPos.X) / _G.sliderTrackAbsSize.X, 0, 1)
        _G.sliderValue = math.floor(_G.sliderCurrentMin + _G.sliderRelative * (_G.sliderCurrentMax - _G.sliderCurrentMin))
        pcall(function()
            _G.sliderCurrentFill.Size = UDim2.new(_G.sliderRelative, 0, 1, 0)
            _G.sliderCurrentThumb.Position = UDim2.new(_G.sliderRelative, 0, 0.5, 0)
            _G.sliderCurrentValueLabel.Text = tostring(_G.sliderValue)
        end)
        if _G.sliderCurrentCb then
            pcall(_G.sliderCurrentCb, _G.sliderValue)
        end
    end

    _G.sliderBtn = Instance.new("TextButton", _G.sliderTrack)
    _G.sliderBtn.Size = UDim2.new(1, 0, 1, 20)
    _G.sliderBtn.Position = UDim2.fromOffset(0, -10)
    _G.sliderBtn.BackgroundTransparency = 1
    _G.sliderBtn.Text = ""
    _G.sliderBtn.ZIndex = 5

    _G.sliderBtnRef = _G.sliderBtn
    _G.sliderTrackRef = _G.sliderTrack
    _G.sliderFillRef = _G.sliderReturnedFill
    _G.sliderThumbRef = _G.sliderReturnedThumb
    _G.sliderValueLabelRef = _G.sliderReturnedValueLabel
    _G.sliderMinRef = min
    _G.sliderMaxRef = max
    _G.sliderCbRef = cb;

    (function(capturedTrack, capturedFill, capturedThumb, capturedValueLabel, capturedMin, capturedMax, capturedCb)
        local capturedDragging = false

        local function doUpdate(inputPos)
            if not capturedTrack or not capturedTrack.Parent then capturedDragging = false return end
            if not capturedValueLabel or not capturedValueLabel.Parent then capturedDragging = false return end
            local absPos = capturedTrack.AbsolutePosition
            local absSize = capturedTrack.AbsoluteSize
            local rel = math.clamp((inputPos.X - absPos.X) / absSize.X, 0, 1)
            local val = math.floor(capturedMin + rel * (capturedMax - capturedMin))
            pcall(function()
                capturedFill.Size = UDim2.new(rel, 0, 1, 0)
                capturedThumb.Position = UDim2.new(rel, 0, 0.5, 0)
                capturedValueLabel.Text = tostring(val)
            end)
            if capturedCb then pcall(capturedCb, val) end
        end

        _G.sliderBtn.MouseButton1Down:Connect(function()
            capturedDragging = true
        end)

        _G.sliderUISChangedConn = Services.UIS.InputChanged:Connect(function(input)
            if not capturedDragging then return end
            if not capturedTrack or not pcall(function() return capturedTrack.Parent end) then
                capturedDragging = false
                return
            end
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                pcall(doUpdate, input.Position)
            end
        end)
        table.insert(_G.AllUISConnections, _G.sliderUISChangedConn)

        _G.sliderUISEndedConn = Services.UIS.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                capturedDragging = false
            end
        end)
        table.insert(_G.AllUISConnections, _G.sliderUISEndedConn)

        _G.sliderBtn.MouseButton1Click:Connect(function()
            if not capturedTrack or not capturedTrack.Parent then return end
            local mouse = Player:GetMouse()
            doUpdate(Vector3.new(mouse.X, mouse.Y, 0))
        end)
    end)(_G.sliderTrack, _G.sliderReturnedFill, _G.sliderReturnedThumb, _G.sliderReturnedValueLabel, min, max, cb)

    _G.sliderTabName = "Unknown"
    for name, page in pairs(Data.Pages) do
        if parent == page or parent:IsDescendantOf(page) then
            _G.sliderTabName = name
            break
        end
    end
    Core.registerModule(text, _G.sliderReturnedCard, parent, _G.sliderTabName, "slider")
    return _G.sliderReturnedCard, _G.sliderReturnedValueLabel, _G.sliderReturnedFill, _G.sliderReturnedThumb
end

