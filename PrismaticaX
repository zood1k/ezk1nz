    Services.TweenService:Create(_G.PX_TabBtns[1].btn, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
end)

_G.PX_TabBtns[2].btn.MouseEnter:Connect(function()
    if not _G.PX_HomeIsOpen or _G.PX_CurrentHomePage == 2 then return end
    Services.TweenService:Create(_G.PX_TabBtns[2].btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.7}):Play()
end)
_G.PX_TabBtns[2].btn.MouseLeave:Connect(function()
    if _G.PX_CurrentHomePage == 2 then return end
    Services.TweenService:Create(_G.PX_TabBtns[2].btn, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
end)

_G.HomeOpen = function()
    if _G.PX_HomeIsOpen or _G.PX_HomeDestroyed then return end
    _G.PX_HomeIsOpen = true
    _G.PX_HomeGui.Enabled = true
    _G.PX_HomeContent.Visible = true
    _G.PX_SwitchHomePage(_G.PX_CurrentHomePage or 1, true)

    if _G.PX_CoreBlurGui then
        _G.PX_CoreBlurGui.Enabled = true
        if _G.PX_CoreBlurFrame then
            _G.PX_CoreBlurFrame.BackgroundTransparency = 1
            Services.TweenService:Create(_G.PX_CoreBlurFrame, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {BackgroundTransparency = 0.45}):Play()
        end
    end

    Services.TweenService:Create(_G.PX_HomeBG, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {BackgroundTransparency = 0.5}):Play()
    Services.TweenService:Create(_G.PX_HomeBlur, TweenInfo.new(0.5, _G.PX_FADE_STYLE), {Size = 18}):Play()
    Services.TweenService:Create(_G.PX_HomeTitle, TweenInfo.new(0.5, _G.PX_FADE_STYLE), {TextTransparency = 0}):Play()
    task.delay(0.08, function()
        Services.TweenService:Create(_G.PX_HomeSub, TweenInfo.new(0.45, _G.PX_FADE_STYLE), {TextTransparency = 0.4}):Play()
    end)

    _G.PX_FadeAllElements(true, 0.4)

    _G.PX_TabBar.BackgroundTransparency = 1
    _G.PX_TabBarStroke.Transparency = 1
    _G.PX_TabIndicator.BackgroundTransparency = 1
    _G.PX_TabIndicatorStroke.Transparency = 1
    for _, entry in ipairs(_G.PX_TabBtns) do entry.label.TextTransparency = 1 end

    Services.TweenService:Create(_G.PX_TabBar, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {BackgroundTransparency = 0.15}):Play()
    Services.TweenService:Create(_G.PX_TabBarStroke, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {Transparency = 0.35}):Play()
    Services.TweenService:Create(_G.PX_TabIndicator, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {BackgroundTransparency = 0}):Play()
    Services.TweenService:Create(_G.PX_TabIndicatorStroke, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {Transparency = 0.3}):Play()
    for _, entry in ipairs(_G.PX_TabBtns) do
        Services.TweenService:Create(entry.label, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {TextTransparency = 0}):Play()
    end
    _G.PX_UpdateTabIndicator(_G.PX_CurrentHomePage, false)
end

_G.HomeClose = function()
    if not _G.PX_HomeIsOpen then return end
    _G.PX_HomeIsOpen = false

    pcall(function()
        for _, cell in ipairs(_G.PX_AllCells or {}) do
            if cell and cell.Parent then
                local h = cell:FindFirstChild("CellHover")
                if h then h.BackgroundTransparency = 1 end
            end
        end
        for _, entry in ipairs(_G.PX_AllCards or {}) do
            if entry and entry.card and entry.card.Parent then
                local h = entry.card:FindFirstChild("CardHover")
                if h then h.BackgroundTransparency = 1 end
            end
        end
    end)

    if _G.PX_CurrentHomePage == 2 then _G.PX_SaveExecPosition() end

    Services.TweenService:Create(_G.PX_HomeBG, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {BackgroundTransparency = 1}):Play()
    Services.TweenService:Create(_G.PX_HomeBlur, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {Size = 0}):Play()
    if _G.PX_CoreBlurFrame then
        Services.TweenService:Create(_G.PX_CoreBlurFrame, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {BackgroundTransparency = 1}):Play()
    end
    Services.TweenService:Create(_G.PX_HomeTitle, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {TextTransparency = 1}):Play()
    Services.TweenService:Create(_G.PX_HomeSub, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {TextTransparency = 1}):Play()

    if _G.PX_CurrentHomePage == 1 then
        _G.PX_FadeAllElements(false, _G.PX_FADE_SPEED)
    else
        _G.PX_FadeExec(false, _G.PX_FADE_SPEED)
    end

    Services.TweenService:Create(_G.PX_TabBar, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {BackgroundTransparency = 1}):Play()
    Services.TweenService:Create(_G.PX_TabBarStroke, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {Transparency = 1}):Play()
    Services.TweenService:Create(_G.PX_TabIndicator, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {BackgroundTransparency = 1}):Play()
    Services.TweenService:Create(_G.PX_TabIndicatorStroke, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {Transparency = 1}):Play()
    for _, entry in ipairs(_G.PX_TabBtns) do
        Services.TweenService:Create(entry.label, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {TextTransparency = 1}):Play()
        Services.TweenService:Create(entry.btn, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {BackgroundTransparency = 1}):Play()
    end

    task.delay(_G.PX_FADE_SPEED + 0.15, function()
        if not _G.PX_HomeIsOpen then
            _G.PX_HomeGui.Enabled = false
            if _G.PX_CoreBlurGui then _G.PX_CoreBlurGui.Enabled = false end
        end
    end)
end

_G.PX_HomeKeyDebounce = false
_G.PX_HomeKeyConn = Services.UIS.InputBegan:Connect(function(input, gp)
    if gp or _G.PX_HomeDestroyed or _G.PX_HomeKeyDebounce then return end
    if input.KeyCode == Enum.KeyCode.RightControl then
        _G.PX_HomeKeyDebounce = true
        _G.HomeToggle()
        task.delay(0.2, function() _G.PX_HomeKeyDebounce = false end)
    end
end)

_G.HomeToggle = function()
    if _G.PX_HomeDestroyed then return end
    if _G.PX_HomeIsOpen then _G.HomeClose() else _G.HomeOpen() end
end
