_G.PrismaticaXToggleGui = function()
    if not UI or not UI.Gui then return end
    Settings.GUI_OPEN = not Settings.GUI_OPEN
    UI.Gui.Enabled = true
    if not Settings.GUI_OPEN then
        Settings.SEARCH_RESTORE_ON_OPEN = SEARCH_OPEN
        if SEARCH_OPEN then CloseSearch() end
    end
    _G.PXToggleTarget = nil
    if Settings.GUI_OPEN then
        _G.PXToggleTarget = UDim2.fromOffset(Settings.GUI_WIDTH, Settings.WINDOW_MINIMIZED and Settings.HEADER_HEIGHT or Settings.ORIGINAL_HEIGHT)
    else
        _G.PXToggleTarget = UDim2.fromOffset(0, 0)
    end
    Services.TweenService:Create(UI.Main, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = _G.PXToggleTarget}):Play()
    -- Тень не показываем, только обновляем размер
    UI.Shadow.Size = _G.PXToggleTarget + UDim2.fromOffset(30, 30)
    UI.Shadow.ImageTransparency = 1
    if Settings.GUI_OPEN then
        if Settings.SEARCH_RESTORE_ON_OPEN then
            task.spawn(function()
                task.wait(0.4)
                OpenSearch()
            end)
            Settings.SEARCH_RESTORE_ON_OPEN = false
        end
    else
        task.delay(0.38, function()
            if not Settings.GUI_OPEN then
                UI.Gui.Enabled = false
            end
        end)
    end
end

