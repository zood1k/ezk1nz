    _G.sliderThumb.AnchorPoint = Vector2.new(0.5, 0.5)
    _G.sliderThumb.Position = UDim2.new((_G.sliderValue - min) / (max - min), 0, 0.5, 0)
    _G.sliderThumb.BackgroundColor3 = Color3.new(1, 1, 1)
