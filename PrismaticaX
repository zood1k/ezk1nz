local MT = {}
MT.__index = function(t, k)
    return rawget(t, k) or function(...)
        local fn = rawget(t, "_"..k)
        if fn then return fn(...) end
    end
end

local Core = setmetatable({}, MT)
Core._addPlaceholder = function(textBox, placeholderText)
    local placeholder = Instance.new("TextLabel", textBox)
    placeholder.Name = "CustomPlaceholder"
    placeholder.Size = UDim2.new(1, -4, 1, 0) -- Small padding for consistency
    placeholder.Position = UDim2.fromOffset(2, 0)
    placeholder.BackgroundTransparency = 1
    placeholder.Text = placeholderText
    placeholder.Font = Enum.Font.FredokaOne -- Force correct font
    placeholder.TextSize = textBox.TextSize
    placeholder.TextColor3 = Color3.new(1, 1, 1) -- Match keybind white
    placeholder.TextXAlignment = textBox.TextXAlignment
    placeholder.TextYAlignment = textBox.TextYAlignment
    placeholder.ZIndex = textBox.ZIndex + 1
    placeholder.Visible = (textBox.Text == "")
    
    textBox:GetPropertyChangedSignal("Text"):Connect(function()
        placeholder.Visible = (textBox.Text == "")
    end)
    
    table.insert(Data.CustomPlaceholders, placeholder)
    return placeholder
end
Core._getGui = function()
    local success, result = pcall(function()
        return gethui() or game:GetService("CoreGui")
    end)
    if success and result then return result end
    return Player:WaitForChild("PlayerGui")
end

Core._saveSettings = function()
    _G.PX_coreSettings = {
        theme = Settings.CURRENT_THEME,
        guiOpacity = Settings.GUI_OPACITY,
        keybind = Settings.CURRENT_BIND.Name,
        guiWidth = Settings.GUI_WIDTH,
        guiHeight = Settings.ORIGINAL_HEIGHT,
        notifSoundId = _G.PX_NotifSoundId or "none",
        notifVolume = _G.PX_NotifVolume or 100
    }
    pcall(function()
        if writefile then
            writefile(Settings.SAVE_FILE, Services.HttpService:JSONEncode(_G.PX_coreSettings))
        end
    end)
end

Core._loadSettings = function()
    local success, result = pcall(function()
        if readfile and isfile and isfile(Settings.SAVE_FILE) then
            return Services.HttpService:JSONDecode(readfile(Settings.SAVE_FILE))
        end
        return nil
    end)
    if success and result then return result end
    return nil
end

Core._getTabAccent = function(tabName)
    local h, s, v = Colors.Accent:ToHSV()
    local off = TAB_HUE_OFFSETS[tabName] or 0
    return Color3.fromHSV((h + off) % 1, math.clamp(s, 0.6, 1), v)
end

