_G.PX_UpdateTabIndicator = function(toPage, animate)
    _G.PX_TabTargetX = _G.PX_TAB_PAD + (toPage - 1) * (_G.PX_TAB_BTN_W + _G.PX_TAB_GAP)

    if animate then
        Services.TweenService:Create(_G.PX_TabIndicator, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Position = UDim2.fromOffset(_G.PX_TabTargetX, _G.PX_TAB_PAD)
        }):Play()
    else
        _G.PX_TabIndicator.Position = UDim2.fromOffset(_G.PX_TabTargetX, _G.PX_TAB_PAD)
    end

    for i, entry in ipairs(_G.PX_TabBtns) do
        if i == toPage then
            Services.TweenService:Create(entry.label, TweenInfo.new(0.2), {TextColor3 = Colors.Base}):Play()
        else
            Services.TweenService:Create(entry.label, TweenInfo.new(0.2), {TextColor3 = Colors.TextSub}):Play()
        end
    end
end

_G.PX_SwitchHomePage = function(toPage, forceRestore)
    if _G.PX_PageSwitching then return end
    if toPage == _G.PX_CurrentHomePage and not forceRestore then return end
    _G.PX_PageSwitching = true

    _G.PX_PrevPage = _G.PX_CurrentHomePage
    _G.PX_CurrentHomePage = toPage

    for i, entry in ipairs(_G.PX_TabBtns) do
        Services.TweenService:Create(entry.btn, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
    end

    if _G.PX_PrevPage == 2 then _G.PX_FadeExec(false, 0.4) end

    Services.TweenService:Create(_G.PX_HomeTitle, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {TextTransparency = 1}):Play()
    Services.TweenService:Create(_G.PX_HomeSub, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {TextTransparency = 1}):Play()

    _G.PX_UpdateTabIndicator(toPage, true)

    if toPage == 1 then
        task.delay(0.15, function()
            if not _G.PX_HomeTitle or not _G.PX_HomeTitle.Parent then return end
            _G.PX_HomeTitle.Text = "Welcome home, " .. Services.Players.LocalPlayer.DisplayName
            _G.PX_HomeSub.Text = "What's up?"
            Services.TweenService:Create(_G.PX_HomeTitle, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {TextTransparency = 0}):Play()
            Services.TweenService:Create(_G.PX_HomeSub, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {TextTransparency = 0.4}):Play()
        end)
        task.delay(0.2, function()
            _G.PX_HomeContent.Visible = true
            _G.PX_FadeAllElements(true, 0.3)
        end)

    elseif toPage == 2 then
        _G.PX_HomeContent.Visible = false
        _G.PX_Page2.Visible = true
        task.delay(0.15, function()
            if not _G.PX_HomeTitle or not _G.PX_HomeTitle.Parent then return end
            _G.PX_HomeTitle.Text = "Script Executor"
            _G.PX_HomeSub.Text = "Execute, inject and manage scripts"
            Services.TweenService:Create(_G.PX_HomeTitle, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {TextTransparency = 0}):Play()
            Services.TweenService:Create(_G.PX_HomeSub, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {TextTransparency = 0.4}):Play()
        end)
        task.delay(0.1, function()
            _G.PX_FadeExec(true, 0.4)
        end)
    end

    task.delay(0.3, function()
        _G.PX_PageSwitching = false
        if _G.PX_CurrentHomePage ~= 2 and _G.PX_Page2 then _G.PX_Page2.Visible = false end
    end)
end

