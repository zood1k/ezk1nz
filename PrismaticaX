_G.PX_SwitchToTab = function(tabIndex)
    if not _G.PX_EditorTabs[tabIndex] then return end
    
    if _G.PX_EditorTabs[_G.PX_CurrentTab] and _G.PX_EditorTabs[_G.PX_CurrentTab].frame then
        _G.PX_EditorTabs[_G.PX_CurrentTab].content = _G.PX_SourceBox.Text
        Services.TweenService:Create(_G.PX_EditorTabs[_G.PX_CurrentTab].frame, TweenInfo.new(0.15), {BackgroundTransparency = 0.7}):Play()
        Services.TweenService:Create(_G.PX_EditorTabs[_G.PX_CurrentTab].stroke, TweenInfo.new(0.15), {Color = Colors.Border, Transparency = 0.7}):Play()
        Services.TweenService:Create(_G.PX_EditorTabs[_G.PX_CurrentTab].label, TweenInfo.new(0.15), {TextColor3 = Colors.TextSub}):Play()
    end
    
    _G.PX_CurrentTab = tabIndex
    _G.PX_SourceBox.Text = _G.PX_EditorTabs[tabIndex].content or ""
    _G.PX_LastLineCount = 0
    _G.PX_UpdateLineNumbers()
    
    Services.TweenService:Create(_G.PX_EditorTabs[tabIndex].frame, TweenInfo.new(0.15), {BackgroundTransparency = 0.3}):Play()
    Services.TweenService:Create(_G.PX_EditorTabs[tabIndex].stroke, TweenInfo.new(0.15), {Color = Colors.Accent, Transparency = 0.4}):Play()
    Services.TweenService:Create(_G.PX_EditorTabs[tabIndex].label, TweenInfo.new(0.15), {TextColor3 = Colors.TextMain}):Play()
end

_G.PX_CloseEditorTab = function(tabIndex)
    if #_G.PX_EditorTabs <= 1 then
        _G.ShowNotification("Cannot close last tab!")
        return
    end
    
    if not _G.PX_EditorTabs[tabIndex] then return end
    
    if _G.PX_EditorTabs[tabIndex].frame then
        _G.PX_EditorTabs[tabIndex].frame:Destroy()
    end
    
    table.remove(_G.PX_EditorTabs, tabIndex)
    
    for i, tab in ipairs(_G.PX_EditorTabs) do
        if tab.frame then
            tab.frame.LayoutOrder = i
        end
    end
    
    if _G.PX_CurrentTab > #_G.PX_EditorTabs then
        _G.PX_CurrentTab = #_G.PX_EditorTabs
    elseif _G.PX_CurrentTab >= tabIndex and _G.PX_CurrentTab > 1 then
        _G.PX_CurrentTab = _G.PX_CurrentTab - 1
    end
    
    if _G.PX_CurrentTab < 1 then
        _G.PX_CurrentTab = 1
    end
    
    _G.PX_SwitchToTab(_G.PX_CurrentTab)
    _G.ShowNotification("Tab closed!")
end

