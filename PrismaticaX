_G.PX_UpdateLineNumbers = function()
    _G.PX_LineUpdateQueued = false
    _G.PX_newLineCount = 1
    for _ in string.gmatch(_G.PX_SourceBox.Text, "\n") do
        _G.PX_newLineCount = _G.PX_newLineCount + 1
    end
    if _G.PX_newLineCount == _G.PX_LastLineCount then return end
    _G.PX_LastLineCount = _G.PX_newLineCount
    _G.PX_lineStr = ""
    for i = 1, _G.PX_newLineCount do
        if i > 1 then _G.PX_lineStr = _G.PX_lineStr .. "\n" end
        _G.PX_lineStr = _G.PX_lineStr .. tostring(i)
    end
    _G.PX_LineNumbers.Text = _G.PX_lineStr
end

_G.PX_SourceBox:GetPropertyChangedSignal("Text"):Connect(function()
    if not _G.PX_LineUpdateQueued then
        _G.PX_LineUpdateQueued = true
        task.defer(_G.PX_UpdateLineNumbers)
    end
    if _G.PX_EditorTabs[_G.PX_CurrentTab] then
        _G.PX_EditorTabs[_G.PX_CurrentTab].content = _G.PX_SourceBox.Text
