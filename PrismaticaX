        local delta = input.Position - searchDragStart
        local targetPos = UDim2.new(
            searchStartPos.X.Scale, searchStartPos.X.Offset + delta.X,
            searchStartPos.Y.Scale, searchStartPos.Y.Offset + delta.Y
