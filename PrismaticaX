_G.LoadSettingsAfterGUI = function()
    task.spawn(function()
        task.wait(0.1)
        _G.autoLoadedSettings = Core.loadSettings()
        if _G.autoLoadedSettings then
            if _G.autoLoadedSettings.theme then
                Settings.CURRENT_THEME = _G.autoLoadedSettings.theme
                _G.autoLoadThemeIdx = 1
                while _G.autoLoadThemeIdx <= #Themes do
                    if Themes[_G.autoLoadThemeIdx].name == _G.autoLoadedSettings.theme then
                        Core.applyTheme(Themes[_G.autoLoadThemeIdx].colors)
                        break
                    end
                    _G.autoLoadThemeIdx = _G.autoLoadThemeIdx + 1
                end
            end
            if _G.autoLoadedSettings.guiOpacity ~= nil then
                Settings.GUI_OPACITY = _G.autoLoadedSettings.guiOpacity
                Core.updateGuiOpacity(_G.autoLoadedSettings.guiOpacity)
                task.wait(0.15)
                pcall(function()
                    if opacityFill and opacityFill.Parent then
                        _G.opacityRestoreRel = _G.autoLoadedSettings.guiOpacity / 100
                        opacityFill.Size = UDim2.new(_G.opacityRestoreRel, 0, 1, 0)
                        opacityThumb.Position = UDim2.new(_G.opacityRestoreRel, 0, 0.5, 0)
                        opacityValueLabel.Text = tostring(_G.autoLoadedSettings.guiOpacity)
                    end
                end)
            end
            if _G.autoLoadedSettings.keybind then
                _G.autoLoadKeycode = Enum.KeyCode[_G.autoLoadedSettings.keybind]
                if _G.autoLoadKeycode then
                    Settings.CURRENT_BIND = _G.autoLoadKeycode
                    if _G.setBindKey then
                        pcall(_G.setBindKey, _G.autoLoadKeycode)
                    end
                end
            end
            if _G.autoLoadedSettings.guiWidth then
                Settings.GUI_WIDTH = _G.autoLoadedSettings.guiWidth
            end
            if _G.autoLoadedSettings.guiHeight then
                Settings.ORIGINAL_HEIGHT = _G.autoLoadedSettings.guiHeight
            end
            if _G.autoLoadedSettings.notifSoundId then
                _G.PX_NotifSoundId = _G.autoLoadedSettings.notifSoundId
                pcall(function()
                    for _, opt in ipairs(_G.PX_SoundDropdownOpts) do
                        if opt.id == _G.PX_NotifSoundId then
                            if _G.PX_SoundDropdownSet then
                                _G.PX_SoundDropdownSet(opt.name)
                            end
                            break
                        end
                    end
                end)
            end
            if _G.autoLoadedSettings.notifVolume ~= nil then
                _G.PX_NotifVolume = _G.autoLoadedSettings.notifVolume
                pcall(function()
                    if _G.PX_NotifVolumeFill and _G.PX_NotifVolumeFill.Parent then
                        _G.PX_volRel = _G.PX_NotifVolume / 200
                        _G.PX_NotifVolumeFill.Size = UDim2.new(_G.PX_volRel, 0, 1, 0)
                        _G.PX_NotifVolumeThumb.Position = UDim2.new(_G.PX_volRel, 0, 0.5, 0)
                        _G.PX_NotifVolumeLabel.Text = tostring(_G.PX_NotifVolume)
                    end
                end)
            end
        end
    end)
end

