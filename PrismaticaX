_G.PX_MakeCard = function(parent, order, h, bgColor, bgTransp)
    _G.PX_c = Instance.new("Frame", parent)
    _G.PX_c.Size = UDim2.new(1, 0, 0, h or (Settings.IS_MOBILE and 56 or 66))
    _G.PX_c.BackgroundColor3 = bgColor or Colors.Card
    _G.PX_c.BackgroundTransparency = 1
    _G.PX_c.BorderSizePixel = 0
    _G.PX_c.LayoutOrder = order
    _G.PX_c.ZIndex = 7
    _G.PX_c.ClipsDescendants = true
    -- [ФИХ 5] Закруглённые края карточки
    Instance.new("UICorner", _G.PX_c).CornerRadius = UDim.new(0, Settings.IS_MOBILE and 12 or 14)
    _G.PX_cStroke = Instance.new("UIStroke", _G.PX_c)
    _G.PX_cStroke.Color = Colors.Border
    _G.PX_cStroke.Transparency = 1
    _G.PX_cStroke.Thickness = 1.2
    _G.PX_c:SetAttribute("NormalTransp", bgTransp or 0.25)
    _G.PX_c:SetAttribute("IsThemeCard", bgColor == nil)
    _G.PX_c:SetAttribute("NormalColor3X", (bgColor or Colors.Card).R)
    _G.PX_c:SetAttribute("NormalColor3Y", (bgColor or Colors.Card).G)
    _G.PX_c:SetAttribute("NormalColor3Z", (bgColor or Colors.Card).B)
    -- Hover overlay — отдельный слой, не мешает FadeAllElements
    _G.PX_cHover = Instance.new("Frame", _G.PX_c)
    _G.PX_cHover.Name = "CardHover"
    _G.PX_cHover.Size = UDim2.fromScale(1, 1)
    _G.PX_cHover.BackgroundColor3 = Color3.new(1, 1, 1)
    _G.PX_cHover.BackgroundTransparency = 1
    _G.PX_cHover.BorderSizePixel = 0
    _G.PX_cHover.ZIndex = _G.PX_c.ZIndex + 1
    Instance.new("UICorner", _G.PX_cHover).CornerRadius = UDim.new(0, Settings.IS_MOBILE and 12 or 14)
    _G.PX_cHover:SetAttribute("IsCardHover", true)
    return _G.PX_c, _G.PX_cStroke
end

