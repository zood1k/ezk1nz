_G.PX_EnsureSoundFolder = function()
    pcall(function()
        if makefolder and not isfolder(_G.PX_SoundFolder) then
            makefolder(_G.PX_SoundFolder)
        end
    end)
end

_G.PX_SaveSoundSetting = function()
    pcall(function()
        _G.PX_EnsureSoundFolder()
        if writefile then
            _G.PX_SoundSaveData = {
                soundId = _G.PX_NotifSoundId or "none",
                volume = _G.PX_NotifVolume or 100
            }
            writefile(_G.PX_SoundFolder .. "/sound_config.json", Services.HttpService:JSONEncode(_G.PX_SoundSaveData))
        end
    end)
end

_G.PX_LoadSoundSetting = function()
    pcall(function()
        _G.PX_EnsureSoundFolder()
        if readfile and isfile and isfile(_G.PX_SoundFolder .. "/sound_config.json") then
            _G.PX_SoundLoadRaw = readfile(_G.PX_SoundFolder .. "/sound_config.json")
            _G.PX_SoundLoadData = Services.HttpService:JSONDecode(_G.PX_SoundLoadRaw)
            if _G.PX_SoundLoadData then
                if _G.PX_SoundLoadData.soundId then
                    _G.PX_NotifSoundId = _G.PX_SoundLoadData.soundId
                end
                if _G.PX_SoundLoadData.volume then
                    _G.PX_NotifVolume = _G.PX_SoundLoadData.volume
                end
            end
        end
    end)
end

_G.PX_PreloadSounds = function()
    pcall(function()
        _G.PX_PreloadFolder = Instance.new("Folder", game:GetService("SoundService"))
        _G.PX_PreloadFolder.Name = "PrismaticaX_SoundCache"
        _G.PX_PreloadSoundIdx = 1
        while _G.PX_PreloadSoundIdx <= #_G.PX_SoundOptions do
            _G.PX_PreloadOpt = _G.PX_SoundOptions[_G.PX_PreloadSoundIdx]
            if _G.PX_PreloadOpt.id ~= "none" then
                _G.PX_PreloadSnd = Instance.new("Sound", _G.PX_PreloadFolder)
                _G.PX_PreloadSnd.Name = _G.PX_PreloadOpt.name
                if string.sub(_G.PX_PreloadOpt.id, 1, 9) == "rbxasset:" then
                    _G.PX_PreloadSnd.SoundId = _G.PX_PreloadOpt.id
                else
                    _G.PX_PreloadSnd.SoundId = "rbxassetid://" .. _G.PX_PreloadOpt.id
                end
                _G.PX_PreloadSnd.Volume = 0
            end
            _G.PX_PreloadSoundIdx = _G.PX_PreloadSoundIdx + 1
        end
        _G.PX_PreloadAssets = {}
        _G.PX_PreloadAllSounds = _G.PX_PreloadFolder:GetChildren()
        _G.PX_PreloadAssetsIdx = 1
        while _G.PX_PreloadAssetsIdx <= #_G.PX_PreloadAllSounds do
            table.insert(_G.PX_PreloadAssets, _G.PX_PreloadAllSounds[_G.PX_PreloadAssetsIdx])
            _G.PX_PreloadAssetsIdx = _G.PX_PreloadAssetsIdx + 1
        end
        game:GetService("ContentProvider"):PreloadAsync(_G.PX_PreloadAssets)
    end)
end

