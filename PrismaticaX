            if _G.PX_CoreBlurGui then pcall(function() _G.PX_CoreBlurGui:Destroy() end) _G.PX_CoreBlurGui = nil end
            if _G.PX_HomeGui then pcall(function() _G.PX_HomeGui:Destroy() end) _G.PX_HomeGui = nil end
        end)
    else
        if _G.PX_HomeServerHB then pcall(function() _G.PX_HomeServerHB:Disconnect() end) _G.PX_HomeServerHB = nil end
        if _G.PX_HomeKeyConn then pcall(function() _G.PX_HomeKeyConn:Disconnect() end) _G.PX_HomeKeyConn = nil end
        if _G.PX_HomeThemeHB then pcall(function() _G.PX_HomeThemeHB:Disconnect() end) _G.PX_HomeThemeHB = nil end
        if _G.PX_HomeBlur then pcall(function() _G.PX_HomeBlur:Destroy() end) _G.PX_HomeBlur = nil end
        if _G.PX_CoreBlurGui then pcall(function() _G.PX_CoreBlurGui:Destroy() end) _G.PX_CoreBlurGui = nil end
