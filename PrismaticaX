_G.RefreshPlayerList = function()
    _G.playerCardIdCounter = 0

    _G.refreshPListChildren = _G.playerListScroll:GetChildren()
    _G.refreshPListIdx = 1
    while _G.refreshPListIdx <= #_G.refreshPListChildren do
        if _G.refreshPListChildren[_G.refreshPListIdx]:IsA("Frame") then
            _G.refreshPListChildren[_G.refreshPListIdx]:Destroy()
        end
        _G.refreshPListIdx = _G.refreshPListIdx + 1
    end

    _G.refreshAllPlayersList = Services.Players:GetPlayers()
    _G.refreshAllPlayersIdx = 1
    while _G.refreshAllPlayersIdx <= #_G.refreshAllPlayersList do
        _G.CreatePlayerCard(_G.refreshAllPlayersList[_G.refreshAllPlayersIdx])
        _G.refreshAllPlayersIdx = _G.refreshAllPlayersIdx + 1
    end

    if _G.playerCountValue and _G.playerCountValue.Parent then
        _G.playerCountValue.Text = tostring(#_G.refreshAllPlayersList) .. " / " .. tostring(Services.Players.MaxPlayers)
    end
end

