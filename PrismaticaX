_G.MainDragButton.InputBegan:Connect(function(input)
    if Settings.WINDOW_MINIMIZED then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        _G.MainDragging = true
        _G.MainDragStart = input.Position
        _G.MainStartPosition = UI.Main.Position
        
        if _G.MainCurrentTween then
            _G.MainCurrentTween:Cancel()
            _G.MainCurrentTween = nil
        end
        if _G.ShadowCurrentTween then
            _G.ShadowCurrentTween:Cancel()
            _G.ShadowCurrentTween = nil
        end
    end
end)

_G.MainDragInputChangedConnection = Services.UIS.InputChanged:Connect(function(input)
    if not _G.MainDragging then return end
    if Settings.WINDOW_MINIMIZED then return end
    
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        _G.MainDragDelta = input.Position - _G.MainDragStart
        _G.MainTargetPos = UDim2.new(
            _G.MainStartPosition.X.Scale,
            _G.MainStartPosition.X.Offset + _G.MainDragDelta.X,
            _G.MainStartPosition.Y.Scale,
            _G.MainStartPosition.Y.Offset + _G.MainDragDelta.Y
        )

        if _G.MainCurrentTween then
            _G.MainCurrentTween:Cancel()
        end
        if _G.ShadowCurrentTween then
            _G.ShadowCurrentTween:Cancel()
        end

        _G.MainCurrentTween = Services.TweenService:Create(UI.Main, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = _G.MainTargetPos
        })
        _G.MainCurrentTween:Play()

        _G.ShadowCurrentTween = Services.TweenService:Create(UI.Shadow, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = _G.MainTargetPos
        })
        _G.ShadowCurrentTween:Play()
    end
end)

_G.MainDragInputEndedConnection = Services.UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if _G.MainDragging then
            _G.MainDragging = false
        end
    end
end)

UI.Resize.InputBegan:Connect(function(input)
    if Settings.WINDOW_MINIMIZED then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        resizeStartSize = UI.Main.Size
        resizeStartMouse = input.Position
    end
end)

Services.UIS.InputChanged:Connect(function(input)
    if Settings.WINDOW_MINIMIZED then return end
    if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        _G.ResizeDelta = input.Position - resizeStartMouse
        _G.ResizeNewWidth = math.clamp(resizeStartSize.X.Offset + _G.ResizeDelta.X, MIN_WIDTH, MAX_WIDTH)
        _G.ResizeNewHeight = math.clamp(resizeStartSize.Y.Offset + _G.ResizeDelta.Y, MIN_HEIGHT, MAX_HEIGHT)
        UI.Main.Size = UDim2.fromOffset(_G.ResizeNewWidth, _G.ResizeNewHeight)
        UI.Shadow.Size = UDim2.fromOffset(_G.ResizeNewWidth + 30, _G.ResizeNewHeight + 30)
        Settings.GUI_WIDTH = _G.ResizeNewWidth
        Settings.ORIGINAL_HEIGHT = _G.ResizeNewHeight
    end
end)

Services.UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if resizing then
            resizing = false
            Core.saveSettings()
        end
    end
end)

