_G.ToastThread = nil
_G.ShowCopyNotification = function(message)
    if _G.ToastThread then
        pcall(function()
            task.cancel(_G.ToastThread)
        end)
        _G.ToastThread = nil
    end
    
    if not UI.ToastContainer or not UI.ToastContainer.Parent then return end
    
    _G.toastBaseOpacity = Settings.GUI_OPACITY / 100 * 0.25
    
    UI.ToastText.Text = message or "Copied!"
    UI.ToastContainer.Visible = true
    UI.ToastContainer.Position = UDim2.new(1, -16, 1, 0)
    UI.ToastBg.BackgroundTransparency = 1
    UI.ToastBg.BackgroundColor3 = Colors.Card
    
    Services.TweenService:Create(UI.ToastContainer, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -16, 1, -16)
    }):Play()
    
    Services.TweenService:Create(UI.ToastBg, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        BackgroundTransparency = _G.toastBaseOpacity
    }):Play()
    
    _G.ToastThread = task.delay(2, function()
        if not UI.ToastContainer or not UI.ToastContainer.Parent then return end
        
        Services.TweenService:Create(UI.ToastContainer, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            Position = UDim2.new(1, -16, 1, 0)
        }):Play()
        
        Services.TweenService:Create(UI.ToastBg, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        
        task.wait(0.35)
        if UI.ToastContainer and UI.ToastContainer.Parent then
            UI.ToastContainer.Visible = false
        end
        _G.ToastThread = nil
    end)
end

