_G.PX_TweenCardContents = function(card, toTransp, duration)
    for _, child in ipairs(card:GetDescendants()) do
        if child:IsA("TextLabel") then
            Services.TweenService:Create(child, TweenInfo.new(duration, Enum.EasingStyle.Quint), {TextTransparency = toTransp}):Play()
        elseif child:IsA("Frame") and not child:FindFirstChildOfClass("UIListLayout") and not child:FindFirstChildOfClass("UIGridLayout") and child.Name ~= "CellHover" and child.Name ~= "CardHover" then
            Services.TweenService:Create(child, TweenInfo.new(duration, Enum.EasingStyle.Quint), {BackgroundTransparency = toTransp == 1 and 1 or child:GetAttribute("OrigTransp") or 0.7}):Play()
        elseif child:IsA("ImageLabel") then
            Services.TweenService:Create(child, TweenInfo.new(duration, Enum.EasingStyle.Quint), {ImageTransparency = toTransp, BackgroundTransparency = 1}):Play()
        end
    end
end

