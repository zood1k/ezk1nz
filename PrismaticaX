        Services.TweenService:Create(_G.NotifFrames[notifId], TweenInfo.new(_G.NOTIF_DISAPPEAR_TIME, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, Settings.IS_MOBILE and 36 or 42),
