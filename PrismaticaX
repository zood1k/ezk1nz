_G.PX_FADE_STYLE = Enum.EasingStyle.Quint

_G.PX_FadeAllElements = function(toVisible, speed)
    _G.PX_fadeTI = TweenInfo.new(speed, _G.PX_FADE_STYLE)

    for _, entry in ipairs(_G.PX_AllCards) do
        (function(card)
            if not card or not card.Parent then return end
            if toVisible then
                _G.PX_nt = card:GetAttribute("NormalTransp") or 0.25
                Services.TweenService:Create(card, _G.PX_fadeTI, {BackgroundTransparency = _G.PX_nt}):Play()
            else
                Services.TweenService:Create(card, _G.PX_fadeTI, {BackgroundTransparency = 1}):Play()
            end
            _G.PX_cS = card:FindFirstChildOfClass("UIStroke")
            if _G.PX_cS then
                Services.TweenService:Create(_G.PX_cS, _G.PX_fadeTI, {Transparency = toVisible and 0.55 or 1}):Play()
            end
            for _, child in ipairs(card:GetDescendants()) do
                if child:IsA("TextLabel") then
                    Services.TweenService:Create(child, _G.PX_fadeTI, {TextTransparency = toVisible and 0 or 1}):Play()
                elseif child:IsA("ImageLabel") then
                    _G.PX_origBg = child:GetAttribute("OrigBgTransp")
                    Services.TweenService:Create(child, _G.PX_fadeTI, {
                        ImageTransparency = toVisible and 0 or 1,
                        BackgroundTransparency = toVisible and (_G.PX_origBg ~= nil and _G.PX_origBg or 1) or 1
                    }):Play()
                    _G.PX_imgS = child:FindFirstChildOfClass("UIStroke")
                    if _G.PX_imgS then
                        Services.TweenService:Create(_G.PX_imgS, _G.PX_fadeTI, {
                            Transparency = toVisible and (child:GetAttribute("OrigStrokeTransp") or 0) or 1
                        }):Play()
                    end
                elseif child:IsA("Frame") and child:FindFirstChildOfClass("UICorner") and child ~= card and child.Name ~= "CellHover" and child.Name ~= "CardHover" then
                    Services.TweenService:Create(child, _G.PX_fadeTI, {
                        BackgroundTransparency = toVisible and (child:GetAttribute("NormalTransp") or 0.72) or 1
                    }):Play()
                end
            end
        end)(entry.card)
    end
end

_G.HomeOpen = function()
    if _G.PX_HomeIsOpen then return end
    if _G.PX_HomeDestroyed then return end
    _G.PX_HomeIsOpen = true
    _G.PX_HomeGui.Enabled = true

    if _G.PX_CoreBlurGui then
        _G.PX_CoreBlurGui.Enabled = true
        if _G.PX_CoreBlurFrame then
            _G.PX_CoreBlurFrame.BackgroundTransparency = 1
            Services.TweenService:Create(_G.PX_CoreBlurFrame, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {BackgroundTransparency = 0.45}):Play()
        end
    end

    Services.TweenService:Create(_G.PX_HomeBG, TweenInfo.new(0.4, _G.PX_FADE_STYLE), {BackgroundTransparency = 0.5}):Play()
    Services.TweenService:Create(_G.PX_HomeBlur, TweenInfo.new(0.5, _G.PX_FADE_STYLE), {Size = 18}):Play()

    Services.TweenService:Create(_G.PX_HomeTitle, TweenInfo.new(0.5, _G.PX_FADE_STYLE), {TextTransparency = 0}):Play()
    task.delay(0.08, function()
        Services.TweenService:Create(_G.PX_HomeSub, TweenInfo.new(0.45, _G.PX_FADE_STYLE), {TextTransparency = 0.4}):Play()
    end)

    _G.PX_FadeAllElements(true, 0.4)
end

_G.HomeClose = function()
    if not _G.PX_HomeIsOpen then return end
    _G.PX_HomeIsOpen = false

    Services.TweenService:Create(_G.PX_HomeBG, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {BackgroundTransparency = 1}):Play()
    Services.TweenService:Create(_G.PX_HomeBlur, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {Size = 0}):Play()

    if _G.PX_CoreBlurFrame then
        Services.TweenService:Create(_G.PX_CoreBlurFrame, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {BackgroundTransparency = 1}):Play()
    end

    Services.TweenService:Create(_G.PX_HomeTitle, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {TextTransparency = 1}):Play()
    Services.TweenService:Create(_G.PX_HomeSub, TweenInfo.new(_G.PX_FADE_SPEED, _G.PX_FADE_STYLE), {TextTransparency = 1}):Play()

    _G.PX_FadeAllElements(false, _G.PX_FADE_SPEED)

    task.delay(_G.PX_FADE_SPEED + 0.05, function()
        if not _G.PX_HomeIsOpen then
            _G.PX_HomeGui.Enabled = false
            if _G.PX_CoreBlurGui then
                _G.PX_CoreBlurGui.Enabled = false
            end
        end
    end)
end

_G.HomeToggle = function()
    if _G.PX_HomeDestroyed then return end
    if _G.PX_HomeIsOpen then _G.HomeClose() else _G.HomeOpen() end
end

_G.PX_DestroyHome = function()
    if _G.PX_HomeDestroyed then return end
    _G.PX_HomeDestroyed = true

    if _G.PX_HomeIsOpen then
        _G.HomeClose()
        task.delay(_G.PX_FADE_SPEED + 0.1, function()
            if _G.PX_HomeServerHB then pcall(function() _G.PX_HomeServerHB:Disconnect() end) _G.PX_HomeServerHB = nil end
            if _G.PX_HomeKeyConn then pcall(function() _G.PX_HomeKeyConn:Disconnect() end) _G.PX_HomeKeyConn = nil end
            if _G.PX_HomeThemeHB then pcall(function() _G.PX_HomeThemeHB:Disconnect() end) _G.PX_HomeThemeHB = nil end
